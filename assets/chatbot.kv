#:kivy 2.0.0
#:import Window kivy.core.window.Window

<MessageBubble>:
    adaptive_height: True
    padding: "5dp"
    spacing: "8dp"

    # Spacer - pushes user messages to the right
    Widget:
        size_hint_x: 1 if root.sender == "user" else 0
        size_hint_y: None
        height: 0

    # LLM Avatar 
    MDBoxLayout:
        size_hint: None, None
        size: ("32dp", "32dp") if root.sender == "llm" else ("0dp", "0dp")
        opacity: 1 if root.sender == "llm" else 0
        pos_hint: {"bottom": 1}
        
        MDIcon:
            icon: app.current_avatar
            font_size: "24dp"
            theme_text_color: "Custom"
            text_color: "gray"

    # The actual Chat Bubble
    MDCard:
        size_hint_y: None
        height: msg_label.height + dp(20)
        size_hint_x: None
        width: msg_label.width + dp(24)
        pos_hint: {"right": 1} if root.sender == "user" else {"left": 1}
        
        md_bg_color: app.current_accent if root.sender == "user" else [0.9, 0.9, 0.92, 1]
        radius: [18, 18, 4, 18] if root.sender == "user" else [18, 18, 18, 4]
        padding: "12dp", "10dp"
        elevation: 0

        MDLabel:
            id: msg_label
            text: root.msg_text
            theme_text_color: "Custom"
            text_color: (1, 1, 1, 1) if root.sender == "user" else (0, 0, 0, 1)
            size_hint: None, None
            
            # Fixed width for proper text wrapping on startup
            width: "260dp"
            text_size: (self.width, None)
            height: self.texture_size[1]
            
            halign: "left"
            valign: "center"

# Main Application Layout
MDScreen:
    md_bg_color: 1, 1, 1, 1 # Pure white background 

    MDBoxLayout:
        orientation: "vertical"

        # MESSENGER STYLE TOP BAR
        MDBoxLayout:
            size_hint_y: None
            height: "60dp"
            padding: "10dp"
            spacing: "10dp"
            md_bg_color: 1, 1, 1, 1 
            
            MDIconButton:
                icon: "arrow-left"
                theme_text_color: "Custom"
                text_color: app.current_accent
                pos_hint: {"center_y": .5}

            MDBoxLayout:
                orientation: "vertical"
                pos_hint: {"center_y": .5}
                spacing: "2dp"
                
                MDLabel:
                    text: "Chattop LLM"
                    font_style: "H6"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: 0, 0, 0, 1
                    adaptive_height: True
                MDLabel:
                    text: "Active now"
                    font_style: "Caption"
                    theme_text_color: "Custom"
                    text_color: 0.5, 0.5, 0.5, 1
                    adaptive_height: True

            MDIconButton:
                icon: "phone"
                theme_text_color: "Custom"
                text_color: app.current_accent
                pos_hint: {"center_y": .5}
            MDIconButton:
                icon: "video"
                theme_text_color: "Custom"
                text_color: app.current_accent
                pos_hint: {"center_y": .5}
            MDIconButton:
                icon: "palette" # Theme Changer
                theme_text_color: "Custom"
                text_color: app.current_accent
                pos_hint: {"center_y": .5}
                on_release: app.change_messenger_theme()
            MDIconButton:
                icon: "android" # Avatar Changer
                theme_text_color: "Custom"
                text_color: app.current_accent
                pos_hint: {"center_y": .5}
                on_release: app.change_chatbot_avatar()

        MDSeparator:

        # CHAT HISTORY AREA
        ScrollView:
            id: scroll_view
            do_scroll_x: False

            MDBoxLayout:
                id: chat_list
                orientation: "vertical"
                adaptive_height: True
                padding: "10dp"
                spacing: "2dp" 

        # MESSENGER STYLE BOTTOM BAR
        MDBoxLayout:
            size_hint_y: None
            height: "60dp"
            padding: "5dp"
            spacing: "5dp"
            md_bg_color: 1, 1, 1, 1
            
            MDIconButton:
                icon: "plus-circle"
                theme_text_color: "Custom"
                text_color: app.current_accent
            MDIconButton:
                icon: "camera"
                theme_text_color: "Custom"
                text_color: app.current_accent
            MDIconButton:
                icon: "image"
                theme_text_color: "Custom"
                text_color: app.current_accent
            MDIconButton:
                icon: "microphone"
                theme_text_color: "Custom"
                text_color: app.current_accent

            MDCard:
                size_hint_y: None
                height: "40dp"
                pos_hint: {"center_y": .5}
                radius: [20, 20, 20, 20]
                md_bg_color: 0.95, 0.95, 0.95, 1
                elevation: 0
                padding: "15dp", "0dp", "5dp", "0dp"

                TextInput:
                    id: text_input
                    hint_text: "Aa"
                    background_color: 0, 0, 0, 0
                    cursor_color: app.current_accent
                    foreground_color: 0, 0, 0, 1
                    multiline: False
                    on_text_validate: app.send_message()

                MDIconButton:
                    icon: "send"
                    theme_text_color: "Custom"
                    text_color: app.current_accent
                    pos_hint: {"center_y": .5}
                    on_release: app.send_message()