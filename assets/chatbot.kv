#:import Window kivy.core.window.Window
#:import dp kivy.metrics.dp
#:import get_color_from_hex kivy.utils.get_color_from_hex

<MessageBubble>:
    adaptive_height: True
    padding: "8dp", "3dp"
    spacing: "8dp"
    _max_width: min(Window.width * 0.68, dp(300))

    # Left spacer — pushes user bubble to the right
    Widget:
        size_hint_x: 1 if root.sender == "user" else None
        width: 0
        size_hint_y: None
        height: 0

    # ── LLM avatar (bottom-aligned, left side) ──
    MDBoxLayout:
        size_hint: None, None
        size: ("36dp", "36dp") if root.sender == "llm" else ("0dp", "0dp")
        opacity: 1 if root.sender == "llm" else 0
        pos_hint: {"bottom": 1}

        canvas.before:
            Color:
                rgba: app.current_accent if app.is_avatar_image == "icon" else [0,0,0,0]
            Ellipse:
                pos: self.pos
                size: self.size

        MDIcon:
            icon: app.current_avatar if app.is_avatar_image == "icon" else ""
            font_size: "20dp"
            theme_text_color: "Custom"
            text_color: [1, 1, 1, 1]
            halign: "center"
            opacity: 1 if app.is_avatar_image == "icon" else 0

        FitImage:
            source: app.current_avatar if app.is_avatar_image == "image" else ""
            radius: [18,]
            opacity: 1 if app.is_avatar_image == "image" else 0

    # ── Chat bubble card ──
    MDCard:
        size_hint: None, None
        width: min(msg_label.texture_size[0] + dp(26), root._max_width)
        height: msg_label.texture_size[1] + dp(22)
        pos_hint: {"right": 1} if root.sender == "user" else {"left": 1}
        md_bg_color: app.current_accent if root.sender == "user" else [0.93, 0.93, 0.95, 1]
        # Messenger-style tail: user = bottom-right flat, llm = bottom-left flat
        radius: [18, 18, 4, 18] if root.sender == "user" else [4, 18, 18, 18]
        padding: "13dp", "9dp"
        elevation: 0

        MDLabel:
            id: msg_label
            text: root.msg_text
            theme_text_color: "Custom"
            text_color: [1, 1, 1, 1] if root.sender == "user" else [0.08, 0.08, 0.12, 1]
            size_hint_x: 1
            size_hint_y: None
            height: self.texture_size[1]
            text_size: min(root._max_width - dp(26), self.width) if self.width > 0 else root._max_width - dp(26), None
            halign: "left"
            valign: "top"
            font_size: "15sp"
            font_name: "Roboto"

    # Right spacer for LLM messages
    Widget:
        size_hint_x: 1 if root.sender == "llm" else None
        width: 0
        size_hint_y: None
        height: 0


# ══════════════════════════════════════════════════════════
#  ROOT LAYOUT
# ══════════════════════════════════════════════════════════
MDBoxLayout:
    orientation: "vertical"
    md_bg_color: [0.965, 0.965, 0.975, 1]

    # ── TOP BAR ──────────────────────────────────────────
    MDBoxLayout:
        size_hint_y: None
        height: "64dp"
        padding: "4dp", "8dp", "4dp", "8dp"
        spacing: "6dp"
        md_bg_color: [1, 1, 1, 1]

        canvas.after:
            Color:
                rgba: [0.9, 0.9, 0.92, 1]
            Line:
                points: self.x, self.y, self.right, self.y
                width: 1

        # Back chevron
        MDIconButton:
            icon: "chevron-left"
            theme_icon_color: "Custom"
            icon_color: app.current_accent
            size_hint: None, None
            size: "40dp", "40dp"
            pos_hint: {"center_y": 0.5}

        # Avatar circle with gradient ring
        MDBoxLayout:
            size_hint: None, None
            size: "44dp", "44dp"
            pos_hint: {"center_y": 0.5}

            canvas.before:
                Color:
                    rgba: app.current_accent
                Ellipse:
                    pos: self.x - dp(2), self.y - dp(2)
                    size: self.width + dp(4), self.height + dp(4)
                Color:
                    rgba: [1, 1, 1, 1]
                Ellipse:
                    pos: self.pos
                    size: self.size

            canvas.after:
                # Online green dot
                Color:
                    rgba: [0.2, 0.85, 0.4, 1]
                Ellipse:
                    pos: self.right - dp(11), self.y + dp(1)
                    size: dp(11), dp(11)

            MDBoxLayout:
                size_hint: None, None
                size: "44dp", "44dp"

                canvas.before:
                    Color:
                        rgba: app.current_accent
                    Ellipse:
                        pos: self.pos
                        size: self.size

                MDIcon:
                    icon: "robot-outline"
                    font_size: "24dp"
                    theme_text_color: "Custom"
                    text_color: [1, 1, 1, 1]
                    halign: "center"
                    pos_hint: {"center_x": 0.5, "center_y": 0.5}

        # Name + status
        MDBoxLayout:
            orientation: "vertical"
            spacing: "2dp"
            pos_hint: {"center_y": 0.5}

            MDLabel:
                text: "Chattop AI"
                bold: True
                theme_text_color: "Primary"
                size_hint_y: None
                height: self.texture_size[1]
                font_size: "16sp"

            MDLabel:
                text: "Active now"
                theme_text_color: "Custom"
                text_color: [0.25, 0.72, 0.38, 1]
                font_size: "12sp"
                size_hint_y: None
                height: self.texture_size[1]

        Widget:

        # Video call icon
        MDIconButton:
            icon: "video-outline"
            theme_icon_color: "Custom"
            icon_color: app.current_accent
            size_hint: None, None
            size: "40dp", "40dp"
            pos_hint: {"center_y": 0.5}

        # Palette / theme color
        MDIconButton:
            icon: "palette-outline"
            theme_icon_color: "Custom"
            icon_color: app.current_accent
            size_hint: None, None
            size: "40dp", "40dp"
            pos_hint: {"center_y": 0.5}
            on_release: app.open_color_picker()

        # Avatar picker
        MDIconButton:
            icon: "account-circle-outline"
            theme_icon_color: "Custom"
            icon_color: app.current_accent
            size_hint: None, None
            size: "40dp", "40dp"
            pos_hint: {"center_y": 0.5}
            on_release: app.open_gallery_for_avatar()

    # ── CHAT SCROLL AREA ────────────────────────────────
    ScrollView:
        id: scroll_view
        do_scroll_x: False
        do_scroll_y: True
        bar_width: "2dp"
        bar_color: [0.75, 0.75, 0.78, 0.5]
        bar_inactive_color: [0.75, 0.75, 0.78, 0.1]

        MDBoxLayout:
            id: chat_list
            orientation: "vertical"
            adaptive_height: True
            padding: "12dp", "14dp"
            spacing: "6dp"

    # ── INPUT BAR ────────────────────────────────────────
    MDBoxLayout:
        size_hint_y: None
        height: "62dp"
        padding: "8dp", "8dp"
        spacing: "6dp"
        md_bg_color: [1, 1, 1, 1]

        canvas.before:
            Color:
                rgba: [0.9, 0.9, 0.92, 1]
            Line:
                points: self.x, self.top, self.right, self.top
                width: 1

        # Emoji button
        MDIconButton:
            icon: "emoticon-outline"
            theme_icon_color: "Custom"
            icon_color: app.current_accent
            size_hint: None, None
            size: "40dp", "40dp"
            pos_hint: {"center_y": 0.5}

        # Photo/attachment button
        MDIconButton:
            icon: "image-outline"
            theme_icon_color: "Custom"
            icon_color: app.current_accent
            size_hint: None, None
            size: "40dp", "40dp"
            pos_hint: {"center_y": 0.5}

        # Rounded pill text input
        MDCard:
            size_hint_x: 1
            size_hint_y: None
            height: "42dp"
            radius: [21,]
            md_bg_color: [0.93, 0.93, 0.95, 1]
            elevation: 0
            padding: "16dp", "0dp"

            MDTextField:
                id: text_input
                hint_text: "Aa"
                mode: "fill"
                fill_color_normal: [0, 0, 0, 0]
                fill_color_focus: [0, 0, 0, 0]
                line_color_normal: [0, 0, 0, 0]
                line_color_focus: [0, 0, 0, 0]
                multiline: False
                font_size: "15sp"
                size_hint_y: None
                height: "42dp"
                on_text_validate: app.send_message()

        # Mic button (decorative)
        MDIconButton:
            icon: "microphone-outline"
            theme_icon_color: "Custom"
            icon_color: app.current_accent
            size_hint: None, None
            size: "40dp", "40dp"
            pos_hint: {"center_y": 0.5}

        # Send button — filled circle
        MDFloatLayout:
            size_hint: None, None
            size: "42dp", "42dp"
            pos_hint: {"center_y": 0.5}

            canvas.before:
                Color:
                    rgba: app.current_accent
                Ellipse:
                    pos: self.pos
                    size: self.size

            MDIconButton:
                icon: "send"
                theme_icon_color: "Custom"
                icon_color: [1, 1, 1, 1]
                size_hint: None, None
                size: "42dp", "42dp"
                pos_hint: {"center_x": 0.5, "center_y": 0.5}
                on_release: app.send_message()
